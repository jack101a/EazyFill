# Node A / primary production host.
# Runs Postgres, Redis, gateways, workers, and scheduler.
# Copy to .env on the VPS deployment host and fill every secret.
# Host-mounted files are stored under ${CONFIG_PATH}/sahelpertest2.

TZ=Asia/Kolkata
CONFIG_PATH=/srv/ajaxhs/config
APP_CONFIG_PATH=/app/backend/config/config.yaml
SA_HELPER_IMAGE=ghcr.io/jack101a/sa-helper:test-production-latest
INSTANCE_ID_PREFIX=node-a
PUBLIC_HTTP_BIND=0.0.0.0
PORT=8088
# Optional home/Node B standby gateway target, e.g. 10.99.0.2:8080.
HAPROXY_NODE_B_GATEWAY=
HAPROXY_NODE_B_BACKUP=true
HAPROXY_NODE_B_WEIGHT=1

APP_ENV=production
APP_MODE=normal
PUBLIC_BASE_URL=https://tata-ocs.002529.xyz
RUN_MIGRATIONS=false
RUN_BACKGROUND_TASKS=false

DB_TYPE=postgresql
LEGACY_DB_TYPE=postgresql

# PostgreSQL - one password source.
PGHOST=sahelpertest2_postgres
PGPORT=5432
PGDATABASE=sa_helper
PGUSER=sa_helper
PGPASSWORD=change_me_postgres_password
# Bind DB to Node A WireGuard/private IP so Node B can reach it.
PG_BIND=10.99.0.1
PG_HOST_PORT=15432
# PostgreSQL physical replication to Node B over WireGuard.
POSTGRES_REPLICATION_USER=sa_helper_replica
POSTGRES_REPLICATION_PASSWORD=change_me_long_replication_password
POSTGRES_REPLICATION_CIDR=10.99.0.2/32
POSTGRES_MAX_WAL_SENDERS=10
POSTGRES_MAX_REPLICATION_SLOTS=10
POSTGRES_WAL_KEEP_SIZE=1024MB

REDIS_ENABLED=true
REDIS_HOST=sahelpertest2_redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
# Bind Redis to Node A WireGuard/private IP so Node B can reach it.
REDIS_BIND=10.99.0.1
REDIS_HOST_PORT=16379
REDIS_PREFIX=sa_helper:

AUTH_HASH_SALT=change_me_random_32_chars_minimum
ADMIN_TOKEN=change_me_long_admin_token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_admin_password

SOLVER_QUEUE_BACKEND=redis
SOLVER_QUEUE_FALLBACK_LOCAL=false
SOLVER_WORKER_CONCURRENCY=2
SOLVER_JOB_TIMEOUT_SECONDS=30
SOLVER_JOB_ATTEMPTS=3
SOLVER_RESULT_TTL_SECONDS=120
CAPTCHA_WORKER_CONCURRENCY=4

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ORDER_TOKEN=

DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_ENABLED=true
