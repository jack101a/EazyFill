# Node B / secondary home host over WireGuard or private network.
# Normal mode runs remote-connected workers and optional gateway-3 against Node A.
# Emergency local Postgres/Redis/API/cloudflared stay warm on the same compose file.
# Copy to .env on the home-server worker host and point PGHOST/REDIS_HOST at Node A.
# Replace 10.99.0.1 with the Node A private/WireGuard IP.
# Normal host-mounted files are under ${CONFIG_PATH}/sahelpertest2.
# Emergency host-mounted files are under ${CONFIG_PATH}/sahelpertest2-emergency.

TZ=Asia/Kolkata
CONFIG_PATH=/srv/ajaxhs/config
APP_CONFIG_PATH=/app/backend/config/config.yaml
SA_HELPER_IMAGE=ghcr.io/jack101a/sa-helper:test-production-latest
INSTANCE_ID_PREFIX=node-b

# Local emergency API listener for direct testing or Cloudflared origin.
HOME_EMERGENCY_BIND=127.0.0.1
HOME_EMERGENCY_PORT=8090

# Optional standby gateway listener for Node A HAProxy over WireGuard/private IP.
# Node A should use HAPROXY_NODE_B_GATEWAY=${NODE_B_GATEWAY_BIND}:${NODE_B_GATEWAY_PORT}.
NODE_B_GATEWAY_BIND=10.99.0.2
NODE_B_GATEWAY_PORT=8080

APP_ENV=production
APP_MODE=standby
PUBLIC_BASE_URL=https://tata-ocs.002529.xyz
FAILOVER_MODE_FILE=/var/lib/sa-helper/failover-mode.json
RUN_MIGRATIONS=false
RUN_BACKGROUND_TASKS=false

DB_TYPE=postgresql
LEGACY_DB_TYPE=postgresql

# Node A PostgreSQL over WireGuard/private network.
PGHOST=10.99.0.1
PGPORT=15432
PGDATABASE=sa_helper
PGUSER=sa_helper
PGPASSWORD=change_me_postgres_password

# Node B local emergency PostgreSQL is bootstrapped from this primary and kept
# as a physical standby until the failover controller promotes it.
POSTGRES_PRIMARY_HOST=10.99.0.1
POSTGRES_PRIMARY_PORT=15432
POSTGRES_REPLICATION_USER=sa_helper_replica
POSTGRES_REPLICATION_PASSWORD=change_me_long_replication_password
POSTGRES_REPLICATION_SLOT=sa_helper_node_b

REDIS_ENABLED=true
REDIS_HOST=10.99.0.1
REDIS_PORT=16379
REDIS_PASSWORD=change_me_redis_password
REDIS_PREFIX=sa_helper:

# Node B local emergency Redis follows this primary until the failover controller
# promotes it with REPLICAOF NO ONE.
REDIS_PRIMARY_HOST=10.99.0.1
REDIS_PRIMARY_PORT=16379
REDIS_PRIMARY_PASSWORD=change_me_redis_password

AUTH_HASH_SALT=change_me_random_32_chars_minimum
ADMIN_TOKEN=change_me_long_admin_token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_admin_password

SOLVER_QUEUE_BACKEND=redis
SOLVER_QUEUE_FALLBACK_LOCAL=false
SOLVER_WORKER_CONCURRENCY=8
SOLVER_JOB_TIMEOUT_SECONDS=30
SOLVER_JOB_ATTEMPTS=3
SOLVER_RESULT_TTL_SECONDS=120
CAPTCHA_WORKER_CONCURRENCY=8

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ORDER_TOKEN=

DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_ENABLED=true

# Emergency local PostgreSQL. Do not point these at Node A.
EMERGENCY_PUBLIC_BASE_URL=
EMERGENCY_PGHOST=sahelper_emergency_postgres
EMERGENCY_PGPORT=5432
EMERGENCY_PGDATABASE=sa_helper
EMERGENCY_PGUSER=sa_helper
EMERGENCY_PGPASSWORD=change_me_emergency_postgres_password

# Emergency local Redis. Do not point these at Node A.
EMERGENCY_REDIS_HOST=sahelper_emergency_redis
EMERGENCY_REDIS_PORT=6379
EMERGENCY_REDIS_PASSWORD=change_me_emergency_redis_password
EMERGENCY_REDIS_PREFIX=sa_helper_emergency:

EMERGENCY_GATEWAY_WORKERS=2
EMERGENCY_SOLVER_JOB_ATTEMPTS=2
EMERGENCY_CAPTCHA_WORKER_CONCURRENCY=4

# Required for warm emergency failover. Configure the tunnel public hostname in
# Cloudflare to target: http://sahelper_emergency_api:80
CLOUDFLARED_TOKEN=
EMERGENCY_READY_URL=http://sahelper_emergency_api/ready

# Private failover controller. It promotes local standby services, then switches
# Cloudflare DNS through fixed hooks.
FAILOVER_CONFIRM_PHRASE=CONFIRM
FAILOVER_CONFIRM_TTL_SECONDS=120
FAILOVER_COMMAND_TIMEOUT_SECONDS=60
FAILOVER_POLL_SECONDS=30
# Primary API down but VPS/Postgres reachable: activate backup URL after 10 minutes.
FAILOVER_API_OUTAGE_SECONDS=600
# Full VPS/Postgres outage: activate local read-only failover after 30 minutes.
FAILOVER_FULL_OUTAGE_SECONDS=1800
# Return Node B to standby only after Node A is healthy for 10 minutes.
FAILOVER_RESTORE_STABLE_SECONDS=600
FAILOVER_PRIMARY_READY_URL=https://tata-ocs.002529.xyz/ready
FAILOVER_PRIMARY_HEALTH_URL=https://tata-ocs.002529.xyz/health
FAILOVER_NODE_B_HEALTH_URL=http://127.0.0.1:8090/health/public
FAILOVER_PRIMARY_DB_HOST=10.99.0.1
FAILOVER_PRIMARY_DB_PORT=15432
FAILOVER_LOCAL_DB_HOST=sahelper_emergency_postgres
FAILOVER_LOCAL_DB_PORT=5432
# Optional fixed commands run when the controller enters a mode. Keep these
# reviewed scripts only; do not put chat/user input here.
FAILOVER_HOOK_STANDBY=
FAILOVER_HOOK_REMOTE_PRIMARY_DB=
FAILOVER_HOOK_FAILOVER_READONLY=
FAILOVER_HOOK_TIMEOUT_SECONDS=120

# Cloudflare DNS switch config used by the failover controller.
# Token should only have DNS edit permission for the required zone.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DNS_NAME=api.example.com
CLOUDFLARE_DNS_TTL=1
CLOUDFLARE_NORMAL_DNS_TYPE=A
CLOUDFLARE_NORMAL_DNS_CONTENT=<vps-public-ip>
CLOUDFLARE_NORMAL_DNS_PROXIED=true
CLOUDFLARE_TUNNEL_DNS_TYPE=CNAME
CLOUDFLARE_TUNNEL_DNS_CONTENT=<tunnel-uuid>.cfargotunnel.com
CLOUDFLARE_TUNNEL_DNS_PROXIED=true
CLOUDFLARE_ALLOW_DELETE_CONFLICTS=false
CLOUDFLARE_RECREATE_ON_UPDATE_FAILURE=false
