SA_HELPER_IMAGE=ghcr.io/jack101a/eazyfill:latest
EAZYFILL_HAPROXY_IMAGE=ghcr.io/jack101a/eazyfill-haproxy:latest

TZ=Asia/Kolkata
CONFIG_PATH=/srv/ajaxhs/config
APP_CONFIG_PATH=/app/backend/config/config.yaml
PUBLIC_BASE_URL=https://eazyfill.002529.xyz
PUBLIC_HTTP_BIND=0.0.0.0
PORT=8097
APP_ENV=production
APP_MODE=normal
RUN_MIGRATIONS=true
RUN_BACKGROUND_TASKS=false

DB_TYPE=postgresql
LEGACY_DB_TYPE=postgresql
PGHOST=test-stack-eazyfill-postgres
PGPORT=5432
PGDATABASE=eazyfill
PGUSER=eazyfill
PGPASSWORD=change_me_postgres_password

# Bind these only to a private/VPN Node A address reachable from Node B.
PG_BIND=10.99.0.1
PG_HOST_PORT=15432

REDIS_ENABLED=true
REDIS_HOST=test-stack-eazyfill-redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_PREFIX=eazyfill:

# Bind these only to a private/VPN Node A address reachable from Node B.
REDIS_BIND=10.99.0.1
REDIS_HOST_PORT=16379

SOLVER_QUEUE_BACKEND=redis
SOLVER_QUEUE_FALLBACK_LOCAL=false
SOLVER_JOB_TIMEOUT_SECONDS=30
SOLVER_JOB_ATTEMPTS=3
SOLVER_RESULT_TTL_SECONDS=120
SOLVER_WORKER_CONCURRENCY=2
CAPTCHA_WORKER_CONCURRENCY=2

AUTH_HASH_SALT=change_me_hash_salt
ADMIN_TOKEN=change_me_admin_token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password
BACKUP_ENCRYPTION_KEY=change_me_backup_encryption_key

OTP_EMAIL_ENABLED=true
OTP_EMAIL_PROVIDER=brevo
BREVO_API_KEY=
OTP_EMAIL_FROM=no-reply.eazyfill@002529.xyz
OTP_EMAIL_FROM_NAME=EazyFill
OTP_EMAIL_REPLY_TO=support.eazyfill@002529.xyz
OTP_DEV_OTP_ENABLED=false

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ORDER_TOKEN=

DISCORD_NOTIFY_ENABLED=false
DISCORD_WEBHOOK_URL=

