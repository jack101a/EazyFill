# Cloudflare DNS switch settings for fixed failover commands.
# Copy to a private env file, fill values, and do not commit secrets.

# Cloudflare API token with DNS Edit permission for this zone.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# The public API hostname to switch.
CLOUDFLARE_DNS_NAME=api.example.com

# Normal mode points the hostname at the VPS edge.
# Use A/AAAA for an IP, or CNAME for another hostname.
CLOUDFLARE_NORMAL_DNS_TYPE=A
CLOUDFLARE_NORMAL_DNS_CONTENT=203.0.113.10
CLOUDFLARE_NORMAL_DNS_PROXIED=true

# Emergency mode points the same hostname at the Cloudflare Tunnel.
# Tunnel DNS content is usually: <tunnel-uuid>.cfargotunnel.com
CLOUDFLARE_TUNNEL_DNS_TYPE=CNAME
CLOUDFLARE_TUNNEL_DNS_CONTENT=00000000-0000-0000-0000-000000000000.cfargotunnel.com
CLOUDFLARE_TUNNEL_DNS_PROXIED=true

# Cloudflare automatic TTL is 1.
CLOUDFLARE_DNS_TTL=1

# Safety controls.
# If multiple DNS records exist for the same name, the script refuses by default.
CLOUDFLARE_ALLOW_DELETE_CONFLICTS=false
# If Cloudflare rejects changing record type, allow delete+create fallback.
CLOUDFLARE_RECREATE_ON_UPDATE_FAILURE=false
