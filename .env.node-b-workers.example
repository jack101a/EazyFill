# EazyFill Node B worker-only stack.
# Copy these values into the Node B Portainer stack environment.
#
# Node B must reach Node A Postgres and Redis over a private/VPN address.
# Do not point these at a public Internet address unless a firewall only allows
# the Node B source IP.

TZ=Asia/Kolkata
EAZYFILL_IMAGE=ghcr.io/jack101a/eazyfill:latest
NODE_B_CONFIG_PATH=/srv/ajaxhs/config/eazyfill-node-b

# Node A private/VPN endpoints. If you use the old WireGuard plan, these are
# usually 10.99.0.1:15432 and 10.99.0.1:16379.
NODE_A_POSTGRES_HOST=10.99.0.1
NODE_A_POSTGRES_PORT=15432
NODE_A_REDIS_HOST=10.99.0.1
NODE_A_REDIS_PORT=16379

APP_ENV=production
APP_MODE=normal
PUBLIC_BASE_URL=https://eazyfill.example.com

# Must match Node A.
POSTGRES_DB=eazyfill
POSTGRES_USER=eazyfill
POSTGRES_PASSWORD=change_me_same_as_node_a
REDIS_PASSWORD=change_me_same_as_node_a
REDIS_PREFIX=eazyfill:
AUTH_HASH_SALT=change_me_same_as_node_a
ADMIN_TOKEN=change_me_same_as_node_a
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_same_as_node_a

# Tune this for the mini PC. Start with 1-2, then increase if CPU stays cool.
SOLVER_WORKER_CONCURRENCY=2
SOLVER_JOB_TIMEOUT_SECONDS=30
SOLVER_JOB_ATTEMPTS=3
SOLVER_RESULT_TTL_SECONDS=120

# Optional unique instance name shown in logs.
INSTANCE_ID=eazyfill-node-b-captcha-worker
