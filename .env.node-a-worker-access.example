# EazyFill Node A worker-access sidecar stack.
# Copy these values into a small Portainer stack on Node A.
#
# Current live Portainer stack discovered by Codex:
# - stack name: test-stack-eazyfill
# - docker network: test-stack-eazyfill-network
# - Postgres alias: test-stack-eazyfill-postgres
# - Redis alias: test-stack-eazyfill-redis
#
# If you redeploy with the clean EazyFill compose, use:
# EAZYFILL_NODE_A_DOCKER_NETWORK=eazyfill-network
# NODE_A_POSTGRES_INTERNAL_HOST=postgres
# NODE_A_REDIS_INTERNAL_HOST=redis

EAZYFILL_NODE_A_DOCKER_NETWORK=test-stack-eazyfill-network
NODE_A_POSTGRES_INTERNAL_HOST=test-stack-eazyfill-postgres
NODE_A_POSTGRES_INTERNAL_PORT=5432
NODE_A_REDIS_INTERNAL_HOST=test-stack-eazyfill-redis
NODE_A_REDIS_INTERNAL_PORT=6379

# Bind to Node A private/VPN IP only. The old WireGuard plan used 10.99.0.1.
POSTGRES_WORKER_BIND=10.99.0.1
POSTGRES_WORKER_PORT=15432
REDIS_WORKER_BIND=10.99.0.1
REDIS_WORKER_PORT=16379
